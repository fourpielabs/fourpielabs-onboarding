# ─────────────────────────────────────────────────────────────
# Supabase — shared project with the main 4Pie Labs marketing
# site, but this is a SEPARATE deployment with its own env vars.
#
# Copy this file to .env.local and fill in the real values (and set
# the same vars in Vercel). .env.local is gitignored — never commit
# real keys.
# ─────────────────────────────────────────────────────────────

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — bypasses Row Level Security. NEVER expose to the
# client or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only — optional webhook the submit action POSTs each
# submission to (e.g. Zapier/Make/n8n/Slack). If unset, the webhook
# step is skipped gracefully and the DB insert still runs.
ONBOARDING_WEBHOOK_URL=

# Server-only — Resend email alerts on new submissions. Both optional:
# if either is unset the email step is skipped gracefully (DB insert
# still runs). The from-domain (mail.fourpielabs.com) must be VERIFIED
# in the Resend account. LEAD_ALERT_TO is a comma-separated recipient
# list, e.g. team@fourpielabs.com,owner@fourpielabs.com
RESEND_API_KEY=
LEAD_ALERT_TO=
